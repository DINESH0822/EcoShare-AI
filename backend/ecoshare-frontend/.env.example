# ============================================================
# EcoShare AI — Frontend Environment Variables (Optional)
# ============================================================
# IMPORTANT: This file shows the OPTIONAL Vite env variable approach.
# The app is designed to fetch API keys from the backend /api/config route
# automatically — you don't NEED to fill these in if the backend .env is set.
#
# But if you want the frontend to work without the backend (e.g., for static
# hosting), copy this to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# Google Maps Platform API Key
# Enable: Maps JS API, Places API, Geocoding API, Maps Embed API
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase Configuration
# From: Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
